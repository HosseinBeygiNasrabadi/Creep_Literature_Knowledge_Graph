:rules_000 a void:Dataset.
:source_000 a rml:LogicalSource;
    rdfs:label "records";
    rml:source "creep_literature_metadata.JSON";
    rml:iterator "$[*]";
    rml:referenceFormulation ql:JSONPath.
:rules_000 void:exampleResource :map_creep_reference_dataset_000.
:map_creep_reference_dataset_000 rml:logicalSource :source_000;
    a rr:TriplesMap;
    rdfs:label "creep_reference_dataset".
:s_000 a rr:SubjectMap.
